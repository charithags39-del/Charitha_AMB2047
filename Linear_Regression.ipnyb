output_type":"stream","name":"stdout","text":["5.3133333333333335\n","76003.0\n"]}]},{"cell_type":"code","source":["#calculate the intercept and coeficient\n","n=len(x_train)\n","num,den=0,0\n","for i in range(n):\n","    num+=(x_train[i]-x_mean)*(y_train[i]-y_mean)\n","    den+=(x_train[i]-x_mean)**2\n","b1=num/den\n","b0=y_mean-(b1*x_mean)\n","print(\"b0:\",b0)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"AUSEgIDhC64Q","executionInfo":{"status":"ok","timestamp":1771559823339,"user_tz":-330,"elapsed":32,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"e8adc083-e534-44b6-d168-d99e30b76302"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["b0: 24740.51581524407\n"]}]},{"cell_type":"code","source":["#predicting results on test dataset\n","y_pred_code=b0+b1*x_test\n","print(y_pred_code)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"RWe898bWItej","executionInfo":{"status":"ok","timestamp":1771559824825,"user_tz":-330,"elapsed":111,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"a70a3bbe-8213-4f79-87ce-f24eece4a588"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["[ 52719.4124531   73944.7823163   55613.78107081  68156.04508088\n"," 103853.25803262  90346.20448331  37282.77982532 126043.41743506\n","  53684.20199233  45965.88567844  81663.09863019  82627.88816942\n","  60437.72876699  55613.78107081 111571.57434651  44036.30659997\n","  35353.20074684  93240.57310102  72015.20323782  63332.0973847 ]\n"]}]},{"cell_type":"code","source":["print(y_test)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"rhmleLrkKoHz","executionInfo":{"status":"ok","timestamp":1771559826268,"user_tz":-330,"elapsed":37,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"7a1b3994-81fa-4064-c088-2a08f5628708"},"execution_count":null,"outputs":[{"output_type":"stream","na