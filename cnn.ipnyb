{"cells":[{"cell_type":"code","source":["import tensorflow as tf"],"metadata":{"id":"j6AVZyeLCJGT"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["#Step1 :load dataset\n","nmsit = tf.keras.datasets.mnist\n","#(train_images, train_labels),(test_images, test_labels)=nmsit.load_data()\n","(x_train, y_train), (x_test,y_test)=nmsit.load_data()"],"metadata":{"id":"CB1bAPS-CJDX","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1774325753337,"user_tz":-330,"elapsed":2409,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"0e31c618-4557-457e-df02-1f09c5bc02bb"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Downloading data from https://storage.googleapis.com/tensorflow/tf-keras-datasets/mnist.npz\n","\u001b[1m11490434/11490434\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m2s\u001b[0m 0us/step\n"]}]},{"cell_type":"code","source":["print(\"Train images shape:\",x_train.shape)\n","print(\"Train labels shape:\",y_train.shape)\n","print(\"Test images shape:\",x_test.shape)\n","print(\"Test labels shape:\",y_test.shape)"],"metadata":{"id":"iUruzjwTCJA2","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1774325838634,"user_tz":-330,"elapsed":53,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"9ed62f99-f661-4ae3-fd24-5fc609930829"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Train images shape: (60000, 28, 28)\n","Train labels shape: (60000,)\n","Test images shape: (10000, 28, 28)\n","Test labels shape: (10000,)\n"]}]},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","#Plot first image\n","plt.imshow(x_train[100],cmap='gray')\n","plt.title(f\"Label: {y_train[100]}\") #show the label\n","plt.axis('off')\n","plt.show()"],"metadata":{"id":"9D4poYFNCI-D","colab":{"base_uri":"https://localhost:8080/","height":428},"executionInfo":{"status":"ok","timestamp":1774326042202,"user_tz":-330,"elapsed":157,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"fb087d20-e174-4f5c-bf8c-a681b3e8bef8"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","#Show First 5 images with labels\n","plt.figure(figsize=(10,2))\n","for i in range(5):\n","    plt.subplot(1,5,i+1)\n","    plt.imshow(x_train[i])\n","    plt.title(f\"Label: {y_train[i]}\")\n","    plt.axis('off')\n","plt.show()"],"metadata":{"id":"TKEoxlxgCI7H","colab":{"base_uri":"https://localhost:8080/","height":192},"executionInfo":{"status":"ok","timestamp":1774326445251,"user_tz":-330,"elapsed":129,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"f49112a9-e8e5-4b78-d9cd-d4c5e97c95cf"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x200 with 5 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["#Step 2: normalize values\n","train_images = x_train / 255.0\n","test_images = x_test / 255.0"],"metadata":{"id":"CRfttb2bF5DQ"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["#Step 3: Add channel dimension (important for CNN)\n","train_images = train_images.reshape((60000,28,28,1))\n","test_images = test_images.reshape((10000,28,28,1))"],"metadata":{"id":"-zf5OLbdGltt"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["from tensorflow.keras import layers, models\n","model=models.Sequential([\n","    layers.Conv2D(16,(3,3),activation='relu', input_shape=(28,28,1)),\n","    layers.MaxPooling2D((2,2)),\n","    layers.Flatten(),\n","    layers.Dense(32,activation='relu'),\n","    layers.Dense(10,activation='softmax')\n","])"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"BlyuzhJeHJr5","executionInfo":{"status":"ok","timestamp":1774327093429,"user_tz":-330,"elapsed":112,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"93e02729-71d9-410e-af2a-fe1c66dc8e18"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/keras/src/layers/convolutional/base_conv.py:113: UserWarning: Do not pass an `input_shape`/`input_dim` argument to a layer. When using Sequential models, prefer using an `Input(shape)` object as the first layer in the model instead.\n","  super().__init__(activity_regularizer=activity_regularizer, **kwargs)\n"]}]},{"cell_type":"code","source":["# Step 5: Compile model\n","model.compile(optimizer='adam',\n","              loss='sparse_categorical_crossentropy',\n","              metrics=['accuracy'])\n","\n","# Step 6: Train model\n","model.fit(train_images, y_train, epochs=3)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ruFc8R5-IteC","executionInfo":{"status":"ok","timestamp":1774327770199,"user_tz":-330,"elapsed":50852,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"26563915-eb06-4b72-e25d-04aa1074202a"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Epoch 1/3\n","\u001b[1m1875/1875\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m18s\u001b[0m 9ms/step - accuracy: 0.9322 - loss: 0.2338\n","Epoch 2/3\n","\u001b[1m1875/1875\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m17s\u001b[0m 9ms/step - accuracy: 0.9734 - loss: 0.0892\n","Epoch 3/3\n","\u001b[1m1875/1875\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m15s\u001b[0m 8ms/step - accuracy: 0.9810 - loss: 0.0620\n"]},{"output_type":"execute_result","data":{"text/plain":["<keras.src.callbacks.history.History at 0x7ce290aee600>"]},"metadata":{},"execution_count":15}]},{"cell_type":"code","source":["# Step 7: Test model\n","test_loss, Test_acc = model.evaluate(test_images, y_test)\n","print(f\"Test accuracy: {Test_acc}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"JTM0uRjgLBL4","executionInfo":{"status":"ok","timestamp":1774327966509,"user_tz":-330,"elapsed":1508,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"87da7607-36d7-4152-f5f4-d586d2692222"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\u001b[1m313/313\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m1s\u001b[0m 4ms/step - accuracy: 0.9791 - loss: 0.0650\n","Test accuracy: 0.9790999889373779\n"]}]},{"cell_type":"code","source":[" import numpy as np\n","import matplotlib.pyplot as plt\n","\n","# Pick a random index\n","index = np.random.randint(0, len(test_images))\n","\n","# Get image and label\n","sample_image = test_images[index]\n","true_label = y_test[index]\n","\n","# Expand dimensions for model input\n","sample_image_input = np.expand_dims(sample_image, axis=0)\n","\n","# Predict\n","prediction = model.predict(sample_image_input) # gives probability from 0 to 9\n","predicted_label = np.argmax(prediction) # gives the index of highest probability\n","\n","# Print results\n","print(\"Original Label:\", true_label)\n","print(\"Predicted Label:\", predicted_label)\n","\n","# Show the image\n","plt.imshow(sample_image.squeeze(), cmap='gray')\n","plt.title(f\"Original: {true_label}, Predicted: {predicted_label}\")\n","plt.axis('off')\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":480},"id":"gALZzUVdMCSN","executionInfo":{"status":"ok","timestamp":1774328449229,"user_tz":-330,"elapsed":243,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"f3139c90-7a82-4545-d54f-0e180dc6f239"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\u001b[1m1/1\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m0s\u001b[0m 76ms/step\n","Original Label: 1\n","Predicted Label: 1\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# Step 4: Build CNN model\n","\n","model = tf.keras.models.Sequential([\n","    tf.keras.layers.Conv2D(16, (3,3), activation='relu', input_shape=(28,28,1)),\n","    tf.keras.layers.MaxPooling2D(2,2),\n","\n","    tf.keras.layers.Conv2D(32, (3,3), activation='relu'), #convolution layer 2\n","    tf.keras.layers.MaxPooling2D(2,2), #pooling layer 2\n","\n","    tf.keras.layers.Flatten(),\n","    tf.keras.layers.Dense(32, activation='relu'),\n","    tf.keras.layers.Dense(10, activation='softmax')\n","])\n","\n","# Step 5: Compile model\n","model.compile(optimizer='adam',\n","              loss='sparse_categorical_crossentropy',\n","              metrics=['accuracy'])\n","\n","# Step 6: Train model\n","model.fit(train_images, y_train, epochs=3)\n","#print(model.summary())\n","\n","# Step 7: Test model\n","test_loss, test_acc = model.evaluate(test_images, y_test)\n","print(\"Accuracy:\", test_acc)"],"metadata":{"id":"nsgahVq-N4cY","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1774330703106,"user_tz":-330,"elapsed":109548,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"885ab018-cd04-48a3-d265-1201099efa00"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/keras/src/layers/convolutional/base_conv.py:113: UserWarning: Do not pass an `input_shape`/`input_dim` argument to a layer. When using Sequential models, prefer using an `Input(shape)` object as the first layer in the model instead.\n","  super().__init__(activity_regularizer=activity_regularizer, **kwargs)\n"]},{"output_type":"stream","name":"stdout","text":["Epoch 1/3\n","\u001b[1m1875/1875\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m25s\u001b[0m 13ms/step - accuracy: 0.9391 - loss: 0.1973\n","Epoch 2/3\n","\u001b[1m1875/1875\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m40s\u001b[0m 12ms/step - accuracy: 0.9797 - loss: 0.0667\n","Epoch 3/3\n","\u001b[1m1875/1875\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m41s\u001b[0m 12ms/step - accuracy: 0.9846 - loss: 0.0494\n","\u001b[1m313/313\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m2s\u001b[0m 5ms/step - accuracy: 0.9892 - loss: 0.0336\n","Accuracy: 0.9891999959945679\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"O69-vcsqWEA6"},"execution_count":null,"outputs":[]}],"metadata":{"colab":{"provenance":[{"file_id":"/v2/external/notebooks/intro.ipynb","timestamp":1774325380189}]},"kernelspec":{"display_name":"Python 3","name":"python3"}},"nbformat":4,"nbformat_minor":0}