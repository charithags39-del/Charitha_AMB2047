w()\n","\n","print(wcss)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":510},"id":"T21Fw96G4Vs6","executionInfo":{"status":"ok","timestamp":1772511063586,"user_tz":-330,"elapsed":587,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"1eea63af-9185-49d5-acbb-a9950e4e2089"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["[269981.28000000014, 183653.3289473683, 106348.37306211119, 73880.64496247198, 44448.45544793369, 40825.16946386947, 33642.57922077922, 26686.837785187785, 24766.471609793436, 23103.122085983905]\n"]}]},{"cell_type":"code","source":["x[y_kmeans==0,0] # these points out of 200 has cluster label 0\n","                    #and their annual income is as follows\n","\n","x[y_kmeans==0,1] # these points out of 200 has cluster label 0\n","                    # and their spending score is as follows"],"metadata":{"id":"yZG27KjD5EVl","executionInfo":{"status":"ok","timestamp":1772513508962,"user_tz":-330,"elapsed":445,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"2b84a9f6-cd6b-4652-aec7-853ed250a755","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":28,"outputs":[{"output_type":"execute_result","data":{"text/plain":["array([61, 55, 52, 60, 54, 60, 45, 50, 46, 51, 46, 56, 55, 52, 59, 51, 59,\n","       50, 48, 59, 47, 55, 42, 49, 56, 47, 54, 53, 48, 52, 42, 51, 55, 41,\n","       44, 57, 46, 58, 55, 60, 46, 55, 41, 49, 40, 42, 52, 47, 50, 42, 49,\n","       41, 48, 59, 55, 56, 42, 50, 46, 43, 48, 52, 54, 42, 46, 48, 50, 43,\n","       59, 43, 57, 56, 40, 58, 35, 34, 40])"]},"metadata":{},"execution_count":28}]},{"cell_type":"code","source":[],"metadata":{"id":"Y3d8B9nUCYWM"},"execution_count":null,"outputs":[]}],"metadata":{"colab":{"provenance":[{"file_id":"/v2/external/notebooks/intro.ipynb","timesta