{"cells":[{"cell_type":"code","source":["import numpy as np\n","crop_yields=np.array([\n","    [12.5,13.2,14.1,13.8,15.2],\n","    [10.3,11.5,10.8,12.1,11.9],\n","    [15.1,14.8,16.2,15.5,16.8],\n","    [11.2,10.9,12.3,11.7,12.8]\n","])\n","print(\"CROP YIELDS ARRAY(tons):\")\n","print(crop_yields)\n","print(f\"\\nShape of the array: {crop_yields.shape}\")\n","print(f\"\\nSize of the array: {crop_yields.size}\")\n","print(f\"\\nDimension of the array: {crop_yields.ndim}\")\n","print(f'Data type of the array: {crop_yields.dtype}')"],"metadata":{"id":"bimCVBJ0cY4c","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1770608807909,"user_tz":-330,"elapsed":22,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"e5c73fb1-de8f-4253-eb31-f173c36f67f0"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["CROP YIELDS ARRAY(tons):\n","[[12.5 13.2 14.1 13.8 15.2]\n"," [10.3 11.5 10.8 12.1 11.9]\n"," [15.1 14.8 16.2 15.5 16.8]\n"," [11.2 10.9 12.3 11.7 12.8]]\n","\n","Shape of the array: (4, 5)\n","\n","Size of the array: 20\n","\n","Dimension of the array: 2\n","Data type of the array: float64\n"]}]},{"cell_type":"code","source":["total_yield=np.sum(crop_yields)\n","avg_yield_per_season=np.mean(crop_yields,axis=0)\n","avg_yield_per_farm=np.mean(crop_yields,axis=1)\n","max_yield=np.max(crop_yields)\n","min_yield=np.min(crop_yields)\n","\n","print(f\"\\nTotal yield: {total_yield}\")\n","print(f\"\\nAverage yield per season: {avg_yield_per_season} tons\")\n","print(f\"\\nAverage yield per farm: {avg_yield_per_farm} tons\")\n","print(f\"\\nMaximum yield: {max_yield} tons\")\n","print(f\"\\nMinimum yield: {min_yield} tons\")"],"metadata":{"id":"Aaj6BC6ncY_d","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1770609291406,"user_tz":-330,"elapsed":27,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"c70f7825-7812-4a3d-988e-f9bb67e33dc6"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","Total yield: 262.7\n","\n","Average yield per season: [12.275 12.6   13.35  13.275 14.175] tons\n","\n","Average yield per farm: [13.76 11.32 15.68 11.78] tons\n","\n","Maximum yield: 16.8 tons\n","\n","Minimum yield: 10.3 tons\n"]}]},{"cell_type":"code","source":["best_farm=np.argmax(avg_yield_per_farm)\n","print(f'\\nBest performing farm:Farm',best_farm+1)\n","print(f\"Their average yield:\",round(avg_yield_per_farm[best_farm],2),\"tons\")"],"metadata":{"id":"S40gtrLbcZDN","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1770610353617,"user_tz":-330,"elapsed":46,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"ef7f542e-16c8-4c27-c10c-841db98a1153"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","Best performing farm:Farm 3\n","Their average yield: 15.68 tons\n"]}]},{"cell_type":"code","source":["mean=np.mean(crop_yields)\n","std=np.std(crop_yields)\n","print(mean)\n","print(std)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"clKmvwd_mSKk","executionInfo":{"status":"ok","timestamp":1770610716086,"user_tz":-330,"elapsed":24,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"a60f7162-9d13-435d-8c1a-4ab9b5d75bb1"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["13.135\n","1.890310821002726\n"]}]},{"cell_type":"code","source":["min=np.argmin(avg_yield_per_farm)\n","print(min)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ETmK5sGZnyhb","executionInfo":{"status":"ok","timestamp":1770610909089,"user_tz":-330,"elapsed":46,"user":{"displayName":"Charitha G S","userId":"18160595251933451949"}},"outputId":"1062b486-d9f2-405f-b98c-c32ffbd50d5a"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["1\n"]}]},{"cell_type"